void setup()
{
  pinMode(7,1);
  pinMode(13,1);
  pinMode(12,1);
  pinMode(8,1);
  pinMode(5,1);
  pinMode(4,1);
  pinMode(3,1);
  pinMode(2,1);
}

void loop()
{
  digitalWrite(12,1);
  delay(100);
  
  digitalWrite(8,1);
  delay(100);
  
  digitalWrite(4,1);
  delay(100);
  
  digitalWrite(3,1);
  delay(100);
  
  digitalWrite(12,0);
  delay(100);
  
  digitalWrite(8,0);
  delay(100);
  
  digitalWrite(4,0);
  delay(100);
  
  digitalWrite(3,0);
  delay(100);
  
  digitalWrite(13,1);
  delay(100);
 
  digitalWrite(7,1);
  delay(100);
  
  digitalWrite(2,1);
  delay(100);
  
  digitalWrite(5,1);
  delay(100);
  
   digitalWrite(13,0);
  delay(100);
  
  digitalWrite(7,0);
  delay(100);
  
  digitalWrite(2,0);
  delay(100);
  
  digitalWrite(5,0);
  delay(100);
  
  }
  
  
  